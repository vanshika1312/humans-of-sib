// Humans of SIB — HRMS for Skillinabox
// Postgres (Neon) in prod. Run `npx prisma db push` after setting DATABASE_URL.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────────────────────────────────────
// Org: Users, Departments, Cities
// ──────────────────────────────────────────────────────────────────────────────

enum Role {
  EMPLOYEE
  MANAGER
  DEPT_HEAD
  HR
  CEO
  ADMIN
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  NOTICE_PERIOD
  EXITED
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

model OrgCounter {
  /// Single row used to issue sequential employee IDs (SIB-00001, …).
  id               String @id @default("singleton")
  nextEmployeeSeq  Int    @default(1)

  updatedAt DateTime @updatedAt
}

model City {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isHQ      Boolean  @default(false)
  users     User[]
  createdAt DateTime @default(now())
}

model Department {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  emoji       String?
  description String?
  headId      String? @unique
  head        User?   @relation("DeptHead", fields: [headId], references: [id])

  users               User[]                 @relation("DeptMembers")
  deptFeedbacks      DeptFeedback[]         @relation("ToDepartment")
  hiringJobs         HiringJob[]
  hiringRequisitions HiringRequisition[]
  createdAt           DateTime               @default(now())
}

model User {
  id            String          @id @default(cuid())
  /// Official (work) email — sign-in; set by HR.
  email         String          @unique
  /// Display / legacy full name; kept in sync with first + last when those are set.
  name          String?
  firstName     String?
  lastName      String?
  /// Personal email (employee enters during onboarding).
  personalEmail String?

  employeeCode  String?         @unique

  image         String?
  title         String?
  bio           String?
  phone         String?
  /// Full postal / residential address (employee / HR; visibility is role-gated).
  residentialAddress String?    @db.Text
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  fatherName    String?
  motherName    String?

  /// Tax IDs — visible only to HR/CEO/Admin and the employee themselves on People.
  pan           String?
  aadhar        String?

  gender        Gender?

  role          Role            @default(EMPLOYEE)
  status        EmployeeStatus  @default(ACTIVE)
  joinedAt      DateTime        @default(now())
  dateOfLeaving DateTime?       @db.Date
  /// Last day of probation (inclusive). Paid casual/sick accrue only after this date passes. Null = not tracking probation (legacy employees treated as confirmed).
  probationEndsAt DateTime?

  /// Date of birth (employee fills).
  birthday      DateTime?
  emailVerified DateTime?
  lastSignInAt  DateTime?

  /// After HR creates the user, the employee must finish self-service before app access.
  invitationPending         Boolean   @default(false)
  onboardingInviteToken     String?   @unique
  onboardingInviteExpiresAt DateTime?

  // Org
  departmentId  String?
  department    Department?     @relation("DeptMembers", fields: [departmentId], references: [id])
  cityId        String?
  city          City?           @relation(fields: [cityId], references: [id])

  // Manager graph
  managerId     String?
  manager       User?           @relation("ReportsTo", fields: [managerId], references: [id])
  reports       User[]          @relation("ReportsTo")

  // Department head (inverse side)
  headedDept    Department?     @relation("DeptHead")

  // NextAuth
  accounts      Account[]
  sessions      Session[]

  // Modules
  journeyEvents       JourneyEvent[]
  enrollments         TrainingEnrollment[]
  certificates        Certificate[]
  attendance          Attendance[]
  leaveBalances       LeaveBalance[]
  leaveRequests       LeaveRequest[]         @relation("LeaveRequester")
  leaveApprovals      LeaveRequest[]         @relation("LeaveApprover")
  regularisationRequests RegularisationRequest[] @relation("RegRequester")
  regularisationReviews  RegularisationRequest[] @relation("RegReviewer")
  ceoFeedback         CEOFeedback[]
  ceoFeedbackReplies  CEOFeedback[]          @relation("CEOReplies")
  deptFeedback        DeptFeedback[]         @relation("FeedbackAuthor")
  wins                Win[]
  winClaps            WinClap[]
  documents           Document[]
  okrs                OKR[]
  oneOnOnesAsManager  OneOnOne[]             @relation("OneOnOneManager")
  oneOnOnesAsReport   OneOnOne[]             @relation("OneOnOneReport")
  pulseResponses      PulseResponse[]
  onboardingTasks     OnboardingTask[]
  offboardingTasks    OffboardingTask[]
  learnerImpact       LearnerImpact[]
  compensation        Compensation?
  salesEntries        SaleEntry[]          @relation("CounsellorSales")
  incentiveSheets     IncentiveSheet[]     @relation("IncentiveOwner")
  lockedSheets        IncentiveSheet[]     @relation("IncentiveLocker")
  approvedSheets      IncentiveSheet[]     @relation("IncentiveApprover")

  recruitmentDailyReports RecruitmentDailyReport[]
  hiringJobsCreated          HiringJob[]            @relation("HiringJobCreatedBy")
  hiringCandidatesCreated    HiringCandidate[]      @relation("HiringCandidateCreatedBy")
  hiringRequisitionsRequested HiringRequisition[]   @relation("HiringRequisitionRequestedBy")
  hiringRequisitionsReviewed  HiringRequisition[]    @relation("HiringRequisitionReviewedBy")
  hiringActivities            HiringActivity[]       @relation("HiringActivityActor")
  hiringApplicationAttachmentsAdded HiringApplicationAttachment[] @relation("HiringApplicationAttachmentAddedBy")
  hiringInterviewTemplatesAuthored HiringInterviewQuestionTemplate[] @relation("HiringInterviewTemplateAuthor")
  hiringApplicationReviewsAuthored HiringApplicationReview[]         @relation("HiringApplicationReviewAuthor")
  hiringResumeImportBatchesCreated HiringResumeImportBatch[]        @relation("HiringResumeImportBatchCreator")
  hiringJobsRemovedFromList        HiringJob[]                      @relation("HiringJobRemovedBy")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([departmentId])
  @@index([cityId])
  @@index([managerId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Recruitment — hiring funnel (Humans of SIB; manual stage counts until live sync)
// ──────────────────────────────────────────────────────────────────────────────

model RecruitmentFunnelStage {
  id        String   @id @default(cuid())
  /// Strip + funnel ordering (not unique — slug is canonical)
  sortOrder Int      @default(0)
  slug      String   @unique
  label     String
  /// For offer_rate_pct the count is interpreted as percentage points (e.g. 10 → 10%)
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecruitmentDailyReport {
  id                 String    @id @default(cuid())
  reportDate         DateTime  @db.Date
  recruiterName      String    @db.VarChar(200)
  locationName       String    @db.VarChar(200)
  submittedByUserId  String?
  submittedBy       User?     @relation(fields: [submittedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([reportDate])
  @@index([submittedByUserId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Hiring (ATS): jobs, candidates, applications — workspace-scoped recruiter tool
// ──────────────────────────────────────────────────────────────────────────────

enum HiringJobStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
}

enum HiringJobWorkArrangement {
  ON_SITE
  REMOTE
  HYBRID
}

enum HiringActivityKind {
  CANDIDATE_CREATED
  CANDIDATE_DUPLICATE_INTAKE
  CANDIDATE_UPDATED
  APPLICATION_CREATED
  APPLICATION_STAGE_CHANGED
}

enum HiringTemplateCategory {
  /// Stage-scoped questionnaire / interviewer prep (shown on applications in that stage).
  QUESTIONNAIRE_GUIDE
  EMAIL
  JOB_POST
  OTHER
}

enum HiringRequisitionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Configurable recruiting funnel — keys are stable (e.g. APPLIED); labels and order are editable.
model HiringPipelineStage {
  id          String   @id @default(cuid())
  /// Uppercase slug, unique (e.g. PHONE_SCREEN).
  key         String   @unique @db.VarChar(80)
  label       String   @db.VarChar(160)
  sortOrder   Int      @default(0)
  isHired     Boolean  @default(false)
  isRejected  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications      HiringApplication[]
  questionTemplates   HiringInterviewQuestionTemplate[]

  @@index([sortOrder])
}

model HiringJob {
  id             String           @id @default(cuid())
  title          String           @db.VarChar(280)
  description    String?          @db.Text
  employmentType String?          @db.VarChar(80)
  /// City / region; pair with workArrangement (On-site / Hybrid typically include a city).
  location       String?          @db.VarChar(200)
  workArrangement HiringJobWorkArrangement?
  experienceRequired String?      @db.VarChar(200)
  salaryRange    String?          @db.VarChar(120)
  skillsRequired String?          @db.Text
  applicationDeadline DateTime?   @db.Date
  openings       Int             @default(1)
  /// Public / job-board button: redirects candidates to your application form (e.g. HRMS). https recommended.
  externalApplyUrl String?       @db.VarChar(2048)
  departmentId   String?
  department     Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  status         HiringJobStatus  @default(DRAFT)
  createdById    String?
  createdBy      User?            @relation("HiringJobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  applications   HiringApplication[]
  resumeImportBatches HiringResumeImportBatch[]
  /// If this job came from an approved headcount request.
  sourcingRequisition HiringRequisition?

  /// If set, hidden from careers + active job lists — restore from Hiring → Job openings → Removed postings.
  deletedAt    DateTime?
  deletedById  String?
  deletedBy    User? @relation("HiringJobRemovedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([departmentId])
  @@index([deletedAt])
}

model HiringRequisition {
  id             String                   @id @default(cuid())
  title          String                   @db.VarChar(280)
  description    String?                  @db.Text
  employmentType String?                  @db.VarChar(80)
  location       String?                  @db.VarChar(200)
  positions      Int                      @default(1)
  justification  String?                  @db.Text
  skillsRequired String?                  @db.Text
  proposedDeadline DateTime?              @db.Date
  departmentId   String?
  department     Department?              @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  requestedByUserId String
  requestedBy       User                  @relation("HiringRequisitionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)

  status            HiringRequisitionStatus @default(PENDING)
  reviewedByUserId String?
  reviewedBy       User?                    @relation("HiringRequisitionReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?
  reviewNote        String?                 @db.Text

  resultingJobId    String?                  @unique
  resultingJob      HiringJob?               @relation(fields: [resultingJobId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([requestedByUserId])
  @@index([createdAt])
}

model HiringCandidate {
  id          String                @id @default(cuid())
  fullName    String                @db.VarChar(200)
  email       String                @db.VarChar(320)
  phone       String?               @db.VarChar(48)
  /// City / region where the candidate is based (separate from the job posting location).
  candidateLocation String?         @db.VarChar(200)
  source      String?               @db.VarChar(120)
  resumeUrl   String?               @db.VarChar(2000)
  notes       String?               @db.Text
  createdById String?
  createdBy   User?                 @relation("HiringCandidateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  applications HiringApplication[]
  activityLog  HiringActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model HiringApplication {
  id          String                   @id @default(cuid())
  jobId       String
  job         HiringJob                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   HiringCandidate          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  pipelineStageId String
  pipelineStage   HiringPipelineStage @relation(fields: [pipelineStageId], references: [id], onDelete: Restrict)
  /// Job board / channel for this submission (falls back to candidate.source in UI when empty).
  applicationSource String?          @db.VarChar(120)
  notes       String?                  @db.Text
  appliedAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  activityLog HiringActivity[]
  attachments HiringApplicationAttachment[]
  reviews     HiringApplicationReview[]

  @@unique([jobId, candidateId])
  @@index([jobId, pipelineStageId])
  @@index([candidateId])
}

/// Résumés and other documents attached to one application submission (beyond the candidate profile résumé).
model HiringApplicationAttachment {
  id            String             @id @default(cuid())
  applicationId String
  application   HiringApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  /// Label shown in the table (filename or title).
  fileName   String @db.VarChar(280)
  /// Public upload path (/hiring-uploads/…) or pasted URL (e.g. Google Drive share link).
  url        String @db.VarChar(2048)
  category   String @default("Resume") @db.VarChar(80)

  addedByUserId String?
  addedBy       User?   @relation("HiringApplicationAttachmentAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([applicationId])
}

model HiringActivity {
  id            String               @id @default(cuid())
  kind          HiringActivityKind
  summary       String               @db.VarChar(500)
  payloadJson   String?              @db.Text
  candidateId   String?
  candidate     HiringCandidate?     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  applicationId String?
  application   HiringApplication?   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actorUserId   String?
  actor         User?                @relation("HiringActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([candidateId, createdAt])
  @@index([applicationId, createdAt])
}

/// Reusable recruiter content: questionnaires by stage, outreach emails, job post snippets, etc.
model HiringInterviewQuestionTemplate {
  id           String                   @id @default(cuid())
  category     HiringTemplateCategory   @default(QUESTIONNAIRE_GUIDE)
  /// Required when category is QUESTIONNAIRE_GUIDE; optional for emails and other global templates.
  pipelineStageId String?
  pipelineStage    HiringPipelineStage? @relation(fields: [pipelineStageId], references: [id], onDelete: SetNull)
  title        String                   @db.VarChar(200)
  body         String                   @db.Text
  sortOrder    Int                      @default(0)

  createdById  String?
  createdBy    User?                    @relation("HiringInterviewTemplateAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([category, pipelineStageId, sortOrder])
}

model HiringApplicationReview {
  id            String             @id @default(cuid())
  applicationId String
  application   HiringApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  rating   Int?
  comment  String                   @db.Text

  authorId String
  author   User                    @relation("HiringApplicationReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime               @default(now())

  @@index([applicationId, createdAt])
}

enum HiringResumeImportSourceChannel {
  UPLOAD
  EMAIL
}

enum HiringResumeImportItemStatus {
  PENDING_PARSE
  PARSED
  IMPORTED
  FAILED
}

/// Bulk résumé intake staging — reviewed before candidates/applications are created.
model HiringResumeImportBatch {
  id                String                         @id @default(cuid())
  createdById       String?
  createdBy         User?                          @relation("HiringResumeImportBatchCreator", fields: [createdById], references: [id], onDelete: SetNull)
  targetJobId       String?
  targetJob         HiringJob?                     @relation(fields: [targetJobId], references: [id], onDelete: SetNull)
  applicationSource String?                        @db.VarChar(120)
  sourceChannel     HiringResumeImportSourceChannel @default(UPLOAD)
  expiresAt         DateTime

  items HiringResumeImportItem[]

  createdAt DateTime @default(now())

  @@index([createdById])
  @@index([expiresAt])
}

model HiringResumeImportItem {
  id                  String                       @id @default(cuid())
  batchId             String
  batch               HiringResumeImportBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  fileName            String                       @db.VarChar(280)
  resumeUrl           String                       @db.VarChar(2048)
  extractedText       String?                      @db.Text
  parsedPayloadJson   String?                      @db.Text
  parseModel          String?                      @db.VarChar(120)
  parsedAt            DateTime?
  status              HiringResumeImportItemStatus @default(PENDING_PARSE)
  error               String?                      @db.VarChar(500)

  createdAt DateTime @default(now())

  @@index([batchId])
}

// ──────────────────────────────────────────────────────────────────────────────
// NextAuth tables (PrismaAdapter v2)
// ──────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────────────────────────────────────
// Personal Journey
// ──────────────────────────────────────────────────────────────────────────────

enum JourneyEventType {
  JOINED
  MILESTONE
  PROMOTION
  AWARD
  WIN
  FEEDBACK_RECEIVED
  TRAINING_COMPLETED
  ANNIVERSARY
  CUSTOM
}

model JourneyEvent {
  id          String            @id @default(cuid())
  userId      String
  type        JourneyEventType
  title       String
  description String?
  emoji       String?
  occurredAt  DateTime          @default(now())
  createdAt   DateTime          @default(now())
  meta        Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}

// ──────────────────────────────────────────────────────────────────────────────
// Internal Trainings + Certificates
// ──────────────────────────────────────────────────────────────────────────────

enum TrainingType {
  SELF_PACED
  LIVE
  WORKSHOP
  READING
}

enum EnrollmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
}

model Training {
  id          String       @id @default(cuid())
  title       String
  description String?
  type        TrainingType @default(SELF_PACED)
  durationMin Int?
  category    String?
  coverImage  String?
  contentUrl  String?
  passingScore Int?        @default(70)
  isPublished Boolean      @default(true)

  enrollments  TrainingEnrollment[]
  certificates Certificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingEnrollment {
  id           String           @id @default(cuid())
  userId       String
  trainingId   String
  status       EnrollmentStatus @default(NOT_STARTED)
  progress     Int              @default(0)
  score        Int?
  startedAt    DateTime?
  completedAt  DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingId])
  @@index([userId])
}

model Certificate {
  id         String   @id @default(cuid())
  userId     String
  trainingId String
  number     String   @unique // e.g. SIB-CERT-000042
  issuedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Attendance + Leaves
// ──────────────────────────────────────────────────────────────────────────────

enum AttendanceMode {
  OFFICE
  WFH
}

/// How this attendance row was created or last updated.
enum AttendanceSource {
  MANUAL
  BIOMETRIC
  REGULARISED
}

/// Normalized punch/day classification from biometric hardware (vendor codes P/A/LT/EL/MO/MI mapped in the webhook).
enum BiometricAttendanceCode {
  PRESENT
  ABSENT
  LATE_ARRIVAL
  EARLY_LEAVE
  MISSED_OUT
  MISSED_IN
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime         @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  mode      AttendanceMode   @default(OFFICE)
  location  String?
  note      String?
  source    AttendanceSource @default(MANUAL)
  /// Device-reported status for this calendar day (BIOMETRIC rows only in practice).
  biometricCode BiometricAttendanceCode?
  /// Idempotency key from biometric vendor (nullable).
  externalRef String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([externalRef])
}

/// Paid-leave usage per policy half-year: half 1 = Jan–Jun, half 2 = Jul–Dec. Unused casual entitlement rolls within the half; resets each Jul 1 & Jan 1.
model LeaveBalance {
  id         String @id @default(cuid())
  userId     String
  periodYear Int
  half       Int     // 1 = Jan–Jun, 2 = Jul–Dec (same calendar periodYear)
  casualUsed Float   @default(0)
  sickUsed   Float   @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodYear, half])
  @@index([periodYear, half])
}

enum RegularisationStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Request to correct attendance (missed punch, wrong mode, etc.).
model RegularisationRequest {
  id              String               @id @default(cuid())
  userId          String
  /// Calendar day being corrected.
  date            DateTime             @db.Date
  reason          String               @db.Text
  requestCheckIn  DateTime?
  requestCheckOut DateTime?
  requestMode     AttendanceMode?
  /// When true (and approved), attendance is set to standard full-day present punches (on-time, full hours) for that date.
  markFullDayPresent Boolean                  @default(false)
  status          RegularisationStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNote      String?

  user       User @relation("RegRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("RegReviewer", fields: [reviewedById], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([status, createdAt])
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
  MENSTRUAL
  BEREAVEMENT
  WEDDING
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id              String       @id @default(cuid())
  userId          String
  approverId      String?
  type            LeaveType
  startDate       DateTime     @db.Date
  endDate         DateTime     @db.Date
  reason          String?
  /// Sick leave: Drive / doc link when policy requires certificate (multi-day contiguous sick or chained after prior approved sick).
  medicalProofUrl String?
  status          LeaveStatus  @default(PENDING)
  respondedAt DateTime?
  responseNote String?
  /// Paid days deducted from leave bank when approved (uses counted weekdays in range; approver may request a smaller total allocated proportionally across half-years).
  appliedLedgerDebitDays Float?
  /// Half-day leave: 0.5 weekday debit and payroll overlap; only valid for a single working day (enforced on submit).
  isHalfDay       Boolean      @default(false)

  user     User  @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("LeaveApprover", fields: [approverId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([approverId])
  @@index([status, createdAt])
}

// ──────────────────────────────────────────────────────────────────────────────
// Feedback: Direct-to-CEO + Cross-Department
// ──────────────────────────────────────────────────────────────────────────────

enum CEOFeedbackCategory {
  IDEA
  CONCERN
  KUDOS
  BUG
  PROCESS
  OTHER
}

enum CEOFeedbackStatus {
  NEW
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

model CEOFeedback {
  id          String               @id @default(cuid())
  userId      String?              // null = anonymous
  anonymous   Boolean              @default(false)
  category    CEOFeedbackCategory  @default(OTHER)
  subject     String
  message     String               @db.Text
  status      CEOFeedbackStatus    @default(NEW)
  response    String?              @db.Text
  respondedById String?
  respondedAt DateTime?

  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  respondedBy User? @relation("CEOReplies", fields: [respondedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum DeptFeedbackType {
  KUDOS
  CONSTRUCTIVE
  REQUEST
}

model DeptFeedback {
  id             String            @id @default(cuid())
  fromUserId     String
  toDepartmentId String
  type           DeptFeedbackType  @default(KUDOS)
  subject        String
  message        String            @db.Text
  isPublic       Boolean           @default(true)

  fromUser     User       @relation("FeedbackAuthor", fields: [fromUserId], references: [id], onDelete: Cascade)
  toDepartment Department @relation("ToDepartment", fields: [toDepartmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([toDepartmentId])
  @@index([fromUserId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Wins Wall / Shoutouts
// ──────────────────────────────────────────────────────────────────────────────

model Win {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  tags        String[] @default([])
  imageUrl    String?

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  claps WinClap[]

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

model WinClap {
  id     String @id @default(cuid())
  winId  String
  userId String

  win  Win  @relation(fields: [winId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([winId, userId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Documents
// ──────────────────────────────────────────────────────────────────────────────

enum DocumentType {
  OFFER_LETTER
  APPOINTMENT_LETTER
  APPRECIATION
  PAYSLIP
  FORM_16
  ID_PROOF
  ADDRESS_PROOF
  NDA
  ESOP
  POLICY
  CERTIFICATE
  OTHER
}

model Document {
  id        String       @id @default(cuid())
  userId    String
  type      DocumentType @default(OTHER)
  title     String
  url       String
  sizeBytes Int?
  mimeType  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

// ──────────────────────────────────────────────────────────────────────────────
// OKRs (year / quarter / month cascading)
// ──────────────────────────────────────────────────────────────────────────────

enum OKRCycle {
  YEAR
  QUARTER
  MONTH
}

enum OKRStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
  ARCHIVED
}

model OKR {
  id          String    @id @default(cuid())
  userId      String
  parentId    String?
  cycle       OKRCycle
  year        Int
  quarter     Int?      // 1-4 (when cycle = QUARTER or MONTH)
  month       Int?      // 1-12 (when cycle = MONTH)
  title       String
  description String?   @db.Text
  progress    Int       @default(0) // 0-100
  status      OKRStatus @default(ON_TRACK)

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   OKR?  @relation("OKRParent", fields: [parentId], references: [id])
  children OKR[] @relation("OKRParent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, year, cycle])
}

// ──────────────────────────────────────────────────────────────────────────────
// 1-on-1 Tracker
// ──────────────────────────────────────────────────────────────────────────────

model OneOnOne {
  id         String   @id @default(cuid())
  managerId  String
  reportId   String
  scheduledAt DateTime
  agenda     String?  @db.Text
  notes      String?  @db.Text
  actionItems Json?   // [{text, owner, dueDate, done}]
  completed  Boolean  @default(false)

  manager User @relation("OneOnOneManager", fields: [managerId], references: [id], onDelete: Cascade)
  report  User @relation("OneOnOneReport", fields: [reportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
  @@index([reportId])
  @@index([scheduledAt])
}

// ──────────────────────────────────────────────────────────────────────────────
// Pulse Surveys (weekly)
// ──────────────────────────────────────────────────────────────────────────────

model PulseResponse {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime @db.Date
  score     Int      // 1-5
  question  String   // rotating weekly question
  comment   String?  @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart])
}

// ──────────────────────────────────────────────────────────────────────────────
// Onboarding Buddy (30 / 60 / 90)
// ──────────────────────────────────────────────────────────────────────────────

model OnboardingTask {
  id          String  @id @default(cuid())
  userId      String
  dueDay      Int     // 30, 60, 90 (days from joinedAt)
  title       String
  description String?
  category    String? // e.g. "Setup", "Meet people", "First project"
  completed   Boolean @default(false)
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, dueDay])
}

// ──────────────────────────────────────────────────────────────────────────────
// Exit / Offboarding
// ──────────────────────────────────────────────────────────────────────────────

model OffboardingTask {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  ownedBy     String?   // e.g. "HR", "IT", "Manager"
  completed   Boolean   @default(false)
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Learner Impact (Skillinabox-unique)
// ──────────────────────────────────────────────────────────────────────────────

model LearnerImpact {
  id        String   @id @default(cuid())
  userId    String
  period    String   // "2026-Q2", "2026-04", "2026"
  metric    String   // "learners_enrolled" | "classes_taken" | "portfolios_shipped" | "income_launched"
  value     Int
  note      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, metric])
  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────────────────
// Compensation (salary — visible only to the employee + CEO/ADMIN/HR)
// ──────────────────────────────────────────────────────────────────────────────

model Compensation {
  id            String   @id @default(cuid())
  userId        String   @unique
  monthlySalary Int      // in INR
  currency      String   @default("INR")
  effectiveFrom DateTime @default(now())
  note          String?  // e.g. "Post-appraisal Apr 2026"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────────────────────────────────────
// Incentives (Sales / Counselling team)
// ──────────────────────────────────────────────────────────────────────────────

// Admin-configurable eligibility statuses (e.g. "Eligible", "Not Eligible").
model IncentiveEligibilityOption {
  id        String           @id @default(cuid())
  label     String           @unique
  color     String           @default("gray")  // "green" | "red" | "amber" | "blue" | "gray"
  order     Int              @default(0)
  sheets    IncentiveSheet[]
  createdAt DateTime         @default(now())

  @@index([order])
}

// Month-level metadata: one record per month shared across the whole team.
// Stores the Google Sheet URL and any global notes for that month.
model IncentivePeriod {
  id        String   @id @default(cuid())
  year      Int
  month     Int      // 1-12
  sheetUrl  String?  // link to the shared Finance / Sales Google Sheet
  note      String?  // e.g. "Q2 incentive run · revised targets"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}

// Configurable payout tiers set by the Sales Head / Admin.
// The slab with the highest minRev that is ≤ total active revenue applies.
model IncentiveSlab {
  id       String   @id @default(cuid())
  label    String   // "Bronze", "Silver", "Gold"
  minRev   Int      // minimum revenue (₹) for this slab
  maxRev   Int?     // null = no upper bound
  rate     Float    // incentive % (e.g. 5.0 = 5%)
  order    Int      @default(0)

  createdAt DateTime @default(now())

  @@index([order])
}

enum SaleEntryStatus {
  ACTIVE
  REFUNDED
  CANCELLED
}

// One row per course enrollment closed by a counsellor.
model SaleEntry {
  id          String          @id @default(cuid())
  userId      String
  month       Int             // 1–12
  year        Int
  studentName String
  courseName  String
  revenue     Int             // amount in INR (paise-free)
  status      SaleEntryStatus @default(ACTIVE)
  note        String?
  saleDate    DateTime        @db.Date
  sheetId     String?

  user  User            @relation("CounsellorSales", fields: [userId], references: [id], onDelete: Cascade)
  sheet IncentiveSheet? @relation(fields: [sheetId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, year, month])
  @@index([sheetId])
}

enum IncentiveSheetStatus {
  DRAFT     // live, counsellor can still add/edit sales
  LOCKED    // Sales Head reviewed & locked; awaiting Accounts approval
  APPROVED  // Accounts Manager approved
  PAID      // payout processed
}

// One sheet per counsellor per month.
model IncentiveSheet {
  id               String               @id @default(cuid())
  userId           String
  month            Int
  year             Int

  grossRevenue     Int                  @default(0)  // sum of all ACTIVE sales
  adjustedRevenue  Int                  @default(0)  // after REFUNDED/CANCELLED are excluded
  monthlyTarget    Int                  @default(0)  // revenue target set by Sales Head for this counsellor
  slabRate         Float                @default(0)  // % rate applied at lock time
  incentiveAmount  Int                  @default(0)  // adjustedRevenue × slabRate / 100
  manualAdjustment Int                  @default(0)  // +/- applied by Sales Head
  finalAmount      Int                  @default(0)  // incentiveAmount + manualAdjustment
  adjustmentNote   String?
  eligibilityOptionId String?
  eligibilityOption   IncentiveEligibilityOption? @relation(fields: [eligibilityOptionId], references: [id], onDelete: SetNull)

  status           IncentiveSheetStatus @default(DRAFT)
  lockedById       String?
  lockedAt         DateTime?
  approvedById     String?
  approvedAt       DateTime?
  paidAt           DateTime?

  user       User          @relation("IncentiveOwner",    fields: [userId],       references: [id])
  lockedBy   User?         @relation("IncentiveLocker",   fields: [lockedById],   references: [id])
  approvedBy User?         @relation("IncentiveApprover", fields: [approvedById], references: [id])
  sales      SaleEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([year, month, status])
}
